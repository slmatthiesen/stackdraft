{
  "name": "@drafture/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dynamo": "vitest run --config vitest.dynamo.config.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "list-pending-facts": "tsx scripts/listPendingFacts.ts",
    "verify-fact": "tsx scripts/verifyFact.ts",
    "refresh-pricing": "tsx jobs/refreshPricing.ts",
    "seed-curated": "tsx scripts/seedCurated.ts",
    "eval": "tsx src/eval/runner.ts",
    "eval:haiku": "tsx src/eval/haikuReview.ts",
    "eval:retrieval": "tsx src/eval/retrievalCalibration.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@aws-sdk/client-dynamodb": "^3.1077.0",
    "@aws-sdk/lib-dynamodb": "^3.1077.0",
    "@drafture/kb": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^9.1.3",
    "@sentry/node": "^10.63.0",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "langfuse": "^3.38.20",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "dynamodb-local": "^0.0.38",
    "tsx": "^4.19.2"
  }
}
