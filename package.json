{
  "name": "drafture",
  "version": "0.1.0",
  "private": true,
  "description": "Describe a system, get a safe, costed AWS design.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @drafture/api dev",
    "dev:web": "pnpm --filter @drafture/web dev",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "list-pending-facts": "pnpm --filter @drafture/api list-pending-facts",
    "verify-fact": "pnpm --filter @drafture/api verify-fact",
    "refresh-pricing": "pnpm --filter @drafture/api refresh-pricing",
    "eval": "pnpm --filter @drafture/api eval"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
