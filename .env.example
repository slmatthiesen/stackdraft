# Drafture configuration — copy to .env and fill in.
# Only this .example file is ever committed. Defaults below are FORKER-SAFE:
# a clone runs cheaply and abuse-protected before you tune anything.

# ── LLM (required) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-sonnet-4-6        # Opus 4.8 is an opt-in quality toggle
LLM_EFFORT=medium                  # low | medium | high
LLM_MAX_TOKENS=8000
LLM_MAX_INPUT_TOKENS=12000

# ── Semantic learning network (RAG over our own approved designs) ────────────
# Embeds approved + curated designs so a near-matching prompt is served instantly
# ($0, no LLM) and weaker matches ground a fresh generation. Provider-abstracted;
# EMBEDDING_PROVIDER=none disables it entirely. Voyage = Anthropic's recommended
# embedder. WITHOUT a key the network auto-disables at boot (generation still works).
# After approving designs (scripts/reviewGenerations.ts), run scripts/backfillEmbeddings.ts.
EMBEDDING_PROVIDER=voyage           # voyage | none
# VOYAGE_API_KEY=pa-REPLACE_ME
EMBEDDING_MODEL=voyage-3-lite
SEMANTIC_RETURN_THRESHOLD=0.80      # cosine ≥ this → serve the nearest design verbatim (calibrated; see scripts/eval/retrievalEval.ts)
SEMANTIC_GROUND_THRESHOLD=0.70      # cosine in [ground, return) → inject as prompt exemplars
SEMANTIC_GROUND_TOPK=2

# ── LLM observability (Langfuse, optional) ───────────────────────────────────
# Both keys set → every LLM call (clarify/generate/terraform) is traced to your
# Langfuse project: prompt, completion, token usage, USD cost, latency. Unset →
# disabled, zero overhead. Get keys from your project settings.
# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_BASE_URL=https://cloud.langfuse.com   # EU cloud; US = https://us.cloud.langfuse.com; or your self-hosted URL

# ── Region / pricing ─────────────────────────────────────────────────────────
DEFAULT_REGION=us-east-1
PRICING_REFRESH_CRON=0 3 1 * *     # monthly; refresh runs as a separate task

# ── Cost + abuse controls (keep these conservative) ──────────────────────────
DAILY_SPEND_CEILING_USD=5          # hard global backstop
PER_IP_DAILY_GENERATIONS=2         # full designs per visitor per day (the real cost lever)
RATE_LIMIT_MAX=10                  # burst only; must allow 1 generate + 3 tier configs
RATE_LIMIT_WINDOW_MS=60000
RESPONSE_CACHE_TTL_MS=86400000     # 24h identical-prompt cache

# ── Bot check (Cloudflare Turnstile) — enabled only when secret is set ───────
# TURNSTILE_SECRET=
# TURNSTILE_SITE_KEY=

# ── Optional hosted-demo access gate (HTTP basic auth) — off when unset ───────
# ACCESS_GATE_USER=
# ACCESS_GATE_PASS=

# ── Research-on-miss — off by default; bounded + ledger-counted when on ───────
RESEARCH_ON_MISS=false
RESEARCH_MAX_CALLS_PER_REQUEST=2

# ── Analytics + SEO + error monitoring (all optional; off when unset) ────────
SITE_ORIGIN=https://drafture.dev       # canonical public origin (no trailing slash) — for absolute sitemap URLs

# Operator product-usage report (GET /api/stats). Unset → the route 404s (off, forker-safe).
# When set, fetch with: curl -H "Authorization: Bearer $STATS_TOKEN" https://drafture.dev/api/stats
# (or /api/stats?token=… for a browser visit). Returns AGGREGATE COUNTS only — never raw IPs.
# STATS_TOKEN=generate-a-long-random-string

# Sentry error monitoring (server). Unset → disabled, zero overhead. sendDefaultPii=false
# and request bodies are NEVER captured (scrubbed in beforeSend), so prompt text never leaves.
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production           # label only (e.g. production / staging)

# The next two are BUILD-TIME web vars (read by `vite build`), so set them in the env that
# runs the web build, then rebuild + redeploy (see docs/deploy.md). Unset → no beacon / no
# client Sentry. Cloudflare Web Analytics is $0, cookieless, and needs NO consent banner.
# VITE_CF_WEB_ANALYTICS_TOKEN=          # CF dashboard → Analytics → Web Analytics → snippet
# VITE_SENTRY_DSN=                      # public browser DSN (safe to ship in the client bundle)

# ── Storage / server ─────────────────────────────────────────────────────────
DB_PATH=./data/drafture.db
PORT=8080
HOST=0.0.0.0
