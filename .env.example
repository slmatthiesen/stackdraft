# Drafture configuration — copy to .env and fill in.
# Only this .example file is ever committed. Defaults below are FORKER-SAFE:
# a clone runs cheaply and abuse-protected before you tune anything.

# ── LLM (required) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-sonnet-4-6        # Opus 4.8 is an opt-in quality toggle
LLM_EFFORT=medium                  # low | medium | high
LLM_MAX_TOKENS=8000
LLM_MAX_INPUT_TOKENS=12000

# ── Semantic learning network (RAG over our own approved designs) ────────────
# Embeds approved + curated designs so a near-matching prompt is served instantly
# ($0, no LLM) and weaker matches ground a fresh generation. Provider-abstracted;
# EMBEDDING_PROVIDER=none disables it entirely. Voyage = Anthropic's recommended
# embedder. WITHOUT a key the network auto-disables at boot (generation still works).
# After approving designs (scripts/reviewGenerations.ts), run scripts/backfillEmbeddings.ts.
EMBEDDING_PROVIDER=voyage           # voyage | none
# VOYAGE_API_KEY=pa-REPLACE_ME
EMBEDDING_MODEL=voyage-3-lite
SEMANTIC_RETURN_THRESHOLD=0.93      # cosine ≥ this → serve the nearest design verbatim
SEMANTIC_GROUND_THRESHOLD=0.82      # cosine in [ground, return) → inject as prompt exemplars
SEMANTIC_GROUND_TOPK=2

# ── Region / pricing ─────────────────────────────────────────────────────────
DEFAULT_REGION=us-east-1
PRICING_REFRESH_CRON=0 3 1 * *     # monthly; refresh runs as a separate task

# ── Cost + abuse controls (keep these conservative) ──────────────────────────
DAILY_SPEND_CEILING_USD=5          # hard global backstop
PER_IP_DAILY_GENERATIONS=2         # full designs per visitor per day (the real cost lever)
RATE_LIMIT_MAX=10                  # burst only; must allow 1 generate + 3 tier configs
RATE_LIMIT_WINDOW_MS=60000
RESPONSE_CACHE_TTL_MS=86400000     # 24h identical-prompt cache

# ── Bot check (Cloudflare Turnstile) — enabled only when secret is set ───────
# TURNSTILE_SECRET=
# TURNSTILE_SITE_KEY=

# ── Optional hosted-demo access gate (HTTP basic auth) — off when unset ───────
# ACCESS_GATE_USER=
# ACCESS_GATE_PASS=

# ── Research-on-miss — off by default; bounded + ledger-counted when on ───────
RESEARCH_ON_MISS=false
RESEARCH_MAX_CALLS_PER_REQUEST=2

# ── Storage / server ─────────────────────────────────────────────────────────
DB_PATH=./data/drafture.db
PORT=8080
HOST=0.0.0.0
